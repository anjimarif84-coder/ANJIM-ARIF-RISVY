# Shared env
NODE_ENV=development

# Database (used by backend)
POSTGRES_USER=elearn
POSTGRES_PASSWORD=elearn_pass
POSTGRES_DB=elearn
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis (used by backend)
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_BASE64=

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

